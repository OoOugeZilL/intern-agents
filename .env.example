# === AskData Configuration ===
# Copy to .env and fill in the values.
# Naming: variable names match the pydantic Settings fields (case-insensitive).
# Both MODELAPIKEY and MODEL_API_KEY work — see askdata/core/config.py.

# --- LLM (required) ---
# DeepSeek or any OpenAI-compatible API
MODELBASEURL=https://api.deepseek.com
MODELNAME=deepseek-chat
MODELAPIKEY=your-api-key-here

# --- Database ---
# Fallback SQLite URL (used when no BIRD database path is found)
DATABASEURL=sqlite:///data/spider2/demo/demo.db

# --- BIRD dataset paths (optional, defaults shown) ---
# BIRDRAWDIR=data/bird/raw
# BIRDPROCESSEDDIR=data/bird/processed
# BIRDDEMODIR=data/bird/demo
# BIRDINSTRUCTIONSDIR=data/bird/instructions

# --- MySQL (feature/mysql-support branch) ---
# USEMYSQL=true
# MYSQLHOST=your-host
# MYSQLPORT=3306
# MYSQLUSER=your-user
# MYSQLPASSWORD=your-password
# MYSQLDATABASE=your-database
