# LLM Configuration (DeepSeek or any OpenAI-compatible API)
MODELBASEURL=https://api.deepseek.com
MODELNAME=deepseek-chat
MODELAPIKEY=your-api-key-here

# Database (optional fallback SQLite URL)
DATABASEURL=sqlite:///data/spider2/demo/demo.db

# MySQL (only needed when USEMYSQL=true, feature/mysql-support branch)
MYSQLHOST=your-mysql-host
MYSQLPORT=3306
MYSQLUSER=your-username
MYSQLPASSWORD=your-password
MYSQLDATABASE=your-database
USEMYSQL=false
